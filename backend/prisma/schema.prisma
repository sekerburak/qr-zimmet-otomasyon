generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEPO
  ZIMMET
  PERSONEL
}

enum AssetStatus {
  ACTIVE
  PASSIVE
  ASSIGNED
}

enum AssignmentStatus {
  ACTIVE
  RETURNED
}

model User {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(PERSONEL)
  createdAt    DateTime     @default(now())
  assignments  Assignment[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Category {
  id               Int        @id @default(autoincrement())
  name             String
  parentCategoryId Int?
  parent           Category?  @relation("CategoryToCategory", fields: [parentCategoryId], references: [id])
  children         Category[] @relation("CategoryToCategory")
  assets           Asset[]

  @@map("categories")
}

model Asset {
  id             Int             @id @default(autoincrement())
  name           String
  categoryId     Int
  category       Category        @relation(fields: [categoryId], references: [id])
  status         AssetStatus     @default(ACTIVE)
  purchaseDate   DateTime?
  createdAt      DateTime        @default(now())
  qrCode         QRCodeRecord?
  assignments    Assignment[]
  stockMovements StockMovement[]

  @@map("assets")
}

model QRCodeRecord {
  id          Int      @id @default(autoincrement())
  assetId     Int      @unique
  asset       Asset    @relation(fields: [assetId], references: [id])
  uuid        String   @unique @default(uuid())
  qrImagePath String?
  generatedAt DateTime @default(now())

  @@map("qr_code_records")
}

model Assignment {
  id           Int              @id @default(autoincrement())
  assetId      Int
  asset        Asset            @relation(fields: [assetId], references: [id])
  userId       Int
  user         User             @relation(fields: [userId], references: [id])
  assignedDate DateTime         @default(now())
  returnDate   DateTime?
  status       AssignmentStatus @default(ACTIVE)

  @@map("assignments")
}

model StockMovement {
  id            Int      @id @default(autoincrement())
  assetId       Int
  asset         Asset    @relation(fields: [assetId], references: [id])
  movementType  String   // IN, OUT, TRANSFER
  quantity      Int      @default(1)
  date          DateTime @default(now())
  performedBy   Int

  @@map("stock_movements")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // LOGIN, CREATE_ASSET, UPDATE_ASSET, DELETE_ASSET, ASSIGN_ASSET, RETURN_ASSET
  entity    String?  // Asset, User, Assignment...
  entityId  Int?
  ipAddress String?
  date      DateTime @default(now())

  @@map("audit_logs")
}
